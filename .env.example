# ── Option A: Your PHP mail API (recommended if you have PHP hosting) ──
# Upload public/contact.php to your PHP host, then set the full URL:
VITE_CONTACT_API_URL=https://YOUR-PHP-DOMAIN.com/contact.php

# ── Option B: EmailJS (only if you are NOT using PHP mail) ──
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
